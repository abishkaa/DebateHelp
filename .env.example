OYLAN_API_KEY=your_oylan_api_key
OYLAN_ASSISTANT_ID=your_oylan_assistant_id
OYLAN_BASE_URL=https://oylan.nu.edu.kz/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/debate_coach
DB_SCHEMA=debate_coach

JWT_SECRET=generate-a-random-secret-with-at-least-32-characters
CSRF_SECRET=
JWT_EXPIRES_IN=7d
PASSWORD_ITERATIONS=600000
VERIFICATION_TOKEN_TTL_SECONDS=86400
RESET_TOKEN_TTL_SECONDS=3600
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENV=development
RATE_LIMIT_GLOBAL_MAX_REQUESTS=300
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
ANALYSIS_RATE_LIMIT_MAX_REQUESTS=30
ANALYSIS_RATE_LIMIT_WINDOW_SECONDS=900
WRITE_RATE_LIMIT_MAX_REQUESTS=120
WRITE_RATE_LIMIT_WINDOW_SECONDS=900
LIVE_RATE_LIMIT_MAX_REQUESTS=60
LIVE_RATE_LIMIT_WINDOW_SECONDS=900
TEAM_RATE_LIMIT_MAX_REQUESTS=30
TEAM_RATE_LIMIT_WINDOW_SECONDS=3600
MAX_REQUEST_BYTES=65536
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
REDIS_URL=
AUTH_EMAIL_DELIVERY=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
AUTH_COOKIE_NAME=debatehelp_session
CSRF_COOKIE_NAME=debatehelp_csrf
CSRF_HEADER_NAME=x-csrf-token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
